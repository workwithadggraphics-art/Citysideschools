{
  "version": 2,
  "routes": [
    { "src": "/",        "dest": "/student.html" },
    { "src": "/student", "dest": "/student.html" },
    { "src": "/admin",   "dest": "/admin.html"   }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
